{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "A7 Server: Init",
      "type": "node-terminal",
      "request": "launch",
      "command": ".\\init.cmd",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "A7 Server: Startup",
      "type": "node-terminal",
      "request": "launch",
      "command": ".\\startup.cmd",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "A7 Server: Stop",
      "type": "node-terminal",
      "request": "launch",
      "command": ".\\stop.cmd",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "A7 GUI",
      "type": "debugpy",
      "request": "launch",
      "module": "a7_gui",
      "cwd": "${workspaceFolder}/gui",
      "python": "${workspaceFolder}/gui/.venv/Scripts/python.exe",
      "preLaunchTask": "gui: ensure venv",
      "console": "integratedTerminal",
      "env": {
        "A7_SERVER_ROOT": "${workspaceFolder}"
      }
    },
    {
      "name": "A7 GUI (terminal)",
      "type": "node-terminal",
      "request": "launch",
      "command": "gui\\run.cmd",
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "gui: ensure venv",
      "env": {
        "A7_SERVER_ROOT": "${workspaceFolder}"
      }
    }
  ]
}
