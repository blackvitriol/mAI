# A7 system identity (do not change unless cloning a second stack)
COMPOSE_PROJECT_NAME=a7_server_1
A7_SYSTEM_NAME=a7_server_1

TZ=UTC

# Pinned image versions (change only when you want to upgrade)
PORTAINER_VERSION=2.39.3
POSTGRES_VERSION=16.8-alpine
NGINX_VERSION=1.27.5-alpine
N8N_VERSION=2.26.6
NODE_VERSION=22-bookworm-slim
UBUNTU_VERSION=22.04
OPENCLAW_VERSION=2026.5.4

# Portainer
PORTAINER_PORT=9443

# n8n
N8N_PORT=5678
N8N_HOST=localhost
N8N_PROTOCOL=http

# PostgreSQL (n8n database)
POSTGRES_USER=n8n
POSTGRES_PASSWORD=changeme
POSTGRES_DB=n8n

# Website (Nginx)
WEB_HTTP_PORT=80
WEB_HTTPS_PORT=443

# LM Studio (llmster GPU — OpenClaw model provider)
# Host folder with your models (Windows: forward slashes, e.g. D:/AI Models)
LM_STUDIO_MODELS_PATH=D:/AI Models
LM_STUDIO_PORT=1234
# Model id from: docker exec a7_server_1-lmstudio lms ls
LM_STUDIO_MODEL_ID=gemma-4-e2b-it
LM_STUDIO_GPU=max
# OpenClaw needs a large context (50k+). Default LM Studio load is 4096.
LM_STUDIO_CONTEXT_LENGTH=65536
LM_API_TOKEN=lmstudio

# OpenClaw
OPENCLAW_GATEWAY_TOKEN=change-me-to-a-random-token
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_DISABLE_BONJOUR=1
