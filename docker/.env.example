# A7 system identity (do not change unless cloning a second stack)
COMPOSE_PROJECT_NAME=a7_server_1
A7_SYSTEM_NAME=a7_server_1

TZ=UTC

# Portainer
PORTAINER_PORT=9443

# n8n
N8N_PORT=5678
N8N_HOST=localhost
N8N_PROTOCOL=http

# PostgreSQL (n8n database)
POSTGRES_USER=n8n
POSTGRES_PASSWORD=changeme
POSTGRES_DB=n8n

# Website (Nginx)
WEB_HTTP_PORT=80
WEB_HTTPS_PORT=443

# Browserless (headless Chrome for n8n Puppeteer/Playwright)
BROWSERLESS_PORT=3000
BROWSERLESS_IMAGE=ghcr.io/browserless/chromium:latest
BROWSERLESS_MAX_SESSIONS=10
BROWSERLESS_PREBOOT_CHROME=true

# Ollama
OLLAMA_PORT=11434
OLLAMA_MODEL=qwen3.5:9b
OLLAMA_EXTRA_MODELS=

# OpenClaw
OPENCLAW_GATEWAY_TOKEN=change-me-to-a-random-token
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_DISABLE_BONJOUR=1
